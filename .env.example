# Copy this file to .env and fill in your key.
# Get a free Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default model
# See https://console.groq.com/docs/models for the current catalogue.
GROQ_MODEL=openai/gpt-oss-120b

# Optional — enables the MCP Tools / external-search retrieval branch
# (case law, out-of-graph-scope questions). Leave unset to keep that
# branch disabled (it will honestly report "no external tool configured"
# instead of fabricating a result). Get a free key at https://tavily.com
# and `pip install tavily-python` to use it.
# TAVILY_API_KEY=your_tavily_api_key_here
