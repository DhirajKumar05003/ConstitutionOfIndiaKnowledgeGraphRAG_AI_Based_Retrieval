# Example Streamlit secrets file.
#
# DO NOT commit a real secrets.toml to git — .gitignore already excludes
# .streamlit/secrets.toml, only this .example file is meant to be checked in.
#
# For Streamlit Community Cloud:
#   App page -> Settings -> Secrets -> paste the contents below (with your
#   real key) -> Save. The app will pick it up automatically via
#   st.secrets, and the key is never shown in the UI or exposed to visitors
#   — see get_deployment_api_key() in app.py.
#
# For local development, copy this file to .streamlit/secrets.toml and fill
# in your own key (or just use a .env file instead — both are supported).

GROQ_API_KEY = "your_groq_api_key_here"

# Optional overrides:
# GROQ_MODEL = "openai/gpt-oss-120b"
# MAX_QUERIES_PER_SESSION = "20"   # cap per-browser-session questions on the shared key; "0" disables the cap
